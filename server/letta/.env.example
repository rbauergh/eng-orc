# Copy to .env and adjust.

# PIN THIS after your first working `docker compose pull` (check
# https://hub.docker.com/r/letta/letta/tags): the self-hosted image is in
# maintenance mode and `latest` has shipped breaking changes unannounced.
# letta-client is pinned in pyproject; keep the pair frozen together.
LETTA_TAG=latest

# llama-swap as seen FROM INSIDE the letta container. If llama-swap binds
# 127.0.0.1 only, rebind it to 0.0.0.0 (systemd unit --listen) or keep
# host-gateway; host.docker.internal resolves to the WSL2 host.
LLAMA_SWAP_URL=http://host.docker.internal:9292/v1
